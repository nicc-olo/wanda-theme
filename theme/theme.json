			"palette": [
				{
					"slug": "background",
					"color": "#ffffff",
					"name": "Background"
				},
				{
					"slug": "background-alt",
					"color": "#f0f0f0",
					"name": "Background Alt"
				},
				{
					"slug": "muted",
					"color": "#5a5a5f",
					"name": "Muted"
				},
				{
					"slug": "foreground",
					"color": "#404040",
					"name": "Foreground"
				},
				{ "slug": "primary-50", "color": "#eef2ff", "name": "Primary 50" },
				{ "slug": "primary-100", "color": "#e0e7ff", "name": "Primary 100" },
				{ "slug": "primary", "color": "#081e5b", "name": "Primary (Base)" },
				{ "slug": "primary-900", "color": "#1e1b4b", "name": "Primary 900" },
				
				{ "slug": "secondary-50", "color": "#eff6ff", "name": "Secondary 50" },
				{ "slug": "secondary-100", "color": "#dbeafe", "name": "Secondary 100" },
				{ "slug": "secondary", "color": "#3d61a5", "name": "Secondary (Base)" },
				{ "slug": "secondary-900", "color": "#1e3a8a", "name": "Secondary 900" },

				{ "slug": "tertiary-50", "color": "#fff1f2", "name": "Tertiary 50" },
				{ "slug": "tertiary-100", "color": "#ffe4e6", "name": "Tertiary 100" },
				{ "slug": "tertiary", "color": "#93112a", "name": "Tertiary (Base)" },
				{ "slug": "tertiary-900", "color": "#4c0519", "name": "Tertiary 900" }
			]
		},
		"typography": {
			"fontFamilies": [
				{
				"fontFamily": "\"Cormorant Garamond\"",
				"name": "Cormorant Garamond",
				"slug": "cormorant-garamond",
				"fontFace": [
					{
						"fontFamily": "Cormorant Garamond",
						"fontStyle": "normal",
						"src": [ "file:./assets/fonts/CormorantGaramond-VariableFont_wght.woff2" ]
					},
					{
						"fontFamily": "Cormorant Garamond",
						"fontStyle": "italic",
						"src": [ "file:./assets/fonts/CormorantGaramond-Italic-VariableFont_wght.woff2" ]
					}
				]
				}
			]
		},
		"layout": {
			"contentSize": "52rem",
			"wideSize": "80rem"
		}
	}
}
